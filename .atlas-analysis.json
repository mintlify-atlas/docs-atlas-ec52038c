  "keyFeatures": [
    "Daily streak tracking with automatic monitoring",
    "Global leaderboards with 24h and 7-day rankings",
    "Multi-language tracking with detailed analytics",
    "Real-time coding activity tracking via VS Code extension",
    "Developer profiles with comprehensive statistics",
    "README badges and embeddable stats cards",
    "Achievement system with gamification",
    "Public API for programmatic access to stats"
  ],
  "publicApiSurface": [
    "POST /api/activity - Track coding activity",
    "GET /api/dashboard - Get dashboard data",
    "GET /api/leaderboard - Get leaderboard rankings",
    "GET /api/profile - Get user profile data",
    "GET /api/stats?username={username}&type={type} - Generate SVG badges",
    "GET /api/public-stats?username={username} - Get public stats in JSON",
    "POST /api/auth/register - Register new user",
    "GET /api/reset-duration - Reset duration tracking"
